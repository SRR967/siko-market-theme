{%- comment -%}
  Section: dtc-cta-releasit
  Clona el botón REAL de Releasit (#_rsi-buy-now-button).
  - Sincroniza clases y estilos (incluida la animación) via MutationObserver.
  - Permite sobreescribir color de fondo y color de texto desde el editor.
{%- endcomment -%}

{%- assign pad_top   = section.settings.padding_top -%}
{%- assign pad_bot   = section.settings.padding_bottom -%}
{%- assign bg_color  = section.settings.btn_bg_color -%}
{%- assign txt_color = section.settings.btn_text_color -%}

<div
  id="dtc-cta-releasit-{{ section.id }}"
  class="dtc-cta-releasit"
  style="padding-top:{{ pad_top }}px;padding-bottom:{{ pad_bot }}px;"
  data-rsi-bg="{{ bg_color }}"
  data-rsi-color="{{ txt_color }}"
  aria-label="Botón de compra"
></div>

<script>
  (function () {
    'use strict';

    var WRAPPER_ID   = 'dtc-cta-releasit-{{ section.id }}';
    var RSI_SELECTOR = '#_rsi-buy-now-button';

    function applyOverrides(clone, bg, color) {
      if (bg    && bg    !== '#ffffff') clone.style.setProperty('background-color', bg,    'important');
      if (color && color !== '#000000') clone.style.setProperty('color',            color, 'important');
    }

    function injectButton() {
      var wrapper  = document.getElementById(WRAPPER_ID);
      if (!wrapper || wrapper.dataset.rsiInjected === 'true') return !!wrapper;

      var original = document.querySelector(RSI_SELECTOR);
      if (!original) return false;

      var bg    = wrapper.dataset.rsiBg    || '';
      var color = wrapper.dataset.rsiColor || '';

      /* ── Clonar el botón completo ── */
      var clone = original.cloneNode(true);
      clone.removeAttribute('id');
      clone.setAttribute('data-rsi-clone', 'true');
      applyOverrides(clone, bg, color);

      /* ── Sincronizar clases y style del original → clon (animación) ── */
      var mo = new MutationObserver(function (mutations) {
        mutations.forEach(function (m) {
          if (m.type === 'attributes') {
            if (m.attributeName === 'class') {
              clone.className = original.className;
            } else if (m.attributeName === 'style') {
              /* copiar todos los estilos inline del original */
              clone.style.cssText = original.style.cssText;
              /* re-aplicar sobreescrituras de color */
              applyOverrides(clone, bg, color);
            }
          }
        });
      });
      mo.observe(original, { attributes: true, attributeFilter: ['class', 'style'] });

      /* ── Click del clon → abre el formulario original ── */
      clone.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        original.click();
      });

      wrapper.appendChild(clone);
      wrapper.dataset.rsiInjected = 'true';
      return true;
    }

    function tryInject(attemptsLeft) {
      if (attemptsLeft <= 0) return;
      if (injectButton()) return;
      window.setTimeout(function () { tryInject(attemptsLeft - 1); }, 300);
    }

    function watchForRsiButton() {
      if (document.querySelector(RSI_SELECTOR)) { tryInject(10); return; }
      var mo = new MutationObserver(function () {
        if (document.querySelector(RSI_SELECTOR)) { mo.disconnect(); tryInject(10); }
      });
      mo.observe(document.body, { childList: true, subtree: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', watchForRsiButton);
    } else {
      watchForRsiButton();
    }
  })();
</script>

<style>
  #dtc-cta-releasit-{{ section.id }} {
    width: 100%;
    box-sizing: border-box;
    display: block;
  }
  #dtc-cta-releasit-{{ section.id }} [data-rsi-clone] {
    width: 100% !important;
    display: block !important;
    box-sizing: border-box !important;
  }
</style>

{% schema %}
{
  "name": "🛒 Botón Releasit",
  "tag": "div",
  "class": "section-dtc-cta-releasit",
  "settings": [
    {
      "type": "paragraph",
      "content": "Muestra el mismo botón que configuraste en Releasit, incluyendo su animación. Opcionalmente puedes sobreescribir los colores."
    },
    {
      "type": "header",
      "content": "Color (opcional)"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Color de fondo del botón",
      "default": "#ffffff",
      "info": "Deja el valor por defecto (#ffffff) para usar el color que configuraste en Releasit"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Color del texto",
      "default": "#000000",
      "info": "Deja el valor por defecto (#000000) para usar el color que configuraste en Releasit"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Botón Releasit"
    }
  ]
}
{% endschema %}
