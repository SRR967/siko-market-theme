{%- comment -%}
  Section: product-landing-images
  Bloques disponibles:
    • image        — Imagen 100% ancho, lazy loading, animación IntersectionObserver
    • cta_releasit — Botón idéntico al de la descripción → dispara .click() en #_rsi-buy-now-button
    • video_grid   — Grid 2 columnas de vídeo igual al que genera dtc-sales-page.js
  Compatible con Shopify OS 2.0 / Dawn + Releasit COD Form.
{%- endcomment -%}

{%- assign hide_desktop = section.settings.hide_on_desktop -%}

{%- if section.blocks.size > 0 -%}
  <div
    id="product-landing-images-{{ section.id }}"
    class="product-landing-images{% if hide_desktop %} pli-hide-desktop{% endif %}"
    aria-label="Landing del producto"
  >

    {%- for block in section.blocks -%}

      {%- comment -%}══════════════════════
        BLOQUE: IMAGEN
      ══════════════════════{%- endcomment -%}
      {%- if block.type == 'image' -%}
        {%- assign img         = block.settings.image -%}
        {%- assign alt_text    = block.settings.alt_text -%}
        {%- assign pad_top     = block.settings.padding_top -%}
        {%- assign pad_bot     = block.settings.padding_bottom -%}
        {%- assign click_action = block.settings.click_action | default: 'none' -%}

        <div
          class="pli-block pli-block--image pli-animate"
          style="padding-top:{{ pad_top }}px;padding-bottom:{{ pad_bot }}px;"
          {{ block.shopify_attributes }}
        >
          {%- if img != blank -%}
            {%- if click_action == 'open_releasit' -%}
              <button
                type="button"
                class="pli-img-btn"
                data-pli-img-action="open_releasit"
                aria-label="{{ alt_text | default: img.alt | default: 'Abrir formulario de compra' }}"
              >
            {%- endif -%}

            {{- img | image_url: width: 1500 | image_tag:
                loading: 'lazy',
                decoding: 'async',
                widths: '375, 550, 750, 1100, 1500',
                sizes: '100vw',
                class: 'pli-image',
                alt: alt_text | default: img.alt | default: product.title
            -}}

            {%- if click_action == 'open_releasit' -%}
              </button>
            {%- endif -%}
          {%- else -%}
            <div class="pli-placeholder-inner">
              {{ 'image' | placeholder_svg_tag: 'pli-placeholder-svg' }}
              <p>Selecciona una imagen en el editor</p>
            </div>
          {%- endif -%}
        </div>

      {%- comment -%}══════════════════════
        BLOQUE: BOTÓN RELEASIT (clon del botón real)
      ══════════════════════{%- endcomment -%}
      {%- elsif block.type == 'cta_releasit' -%}
        {%- assign btn_pad_top = block.settings.padding_top -%}
        {%- assign btn_pad_bot = block.settings.padding_bottom -%}

        <div
          class="pli-block pli-block--cta pli-animate"
          data-pli-rsi-clone-target="true"
          style="padding-top:{{ btn_pad_top }}px;padding-bottom:{{ btn_pad_bot }}px;"
          {{ block.shopify_attributes }}
        ></div>

      {%- comment -%}══════════════════════
        BLOQUE: GRID DE VIDEOS (2 columnas)
      ══════════════════════{%- endcomment -%}
      {%- elsif block.type == 'video_grid' -%}
        {%- assign video_a     = block.settings.video_url_a -%}
        {%- assign video_b     = block.settings.video_url_b -%}
        {%- assign grid_bg     = block.settings.bg_color -%}
        {%- assign vg_pad_top  = block.settings.padding_top -%}
        {%- assign vg_pad_bot  = block.settings.padding_bottom -%}

        {%- if video_a != blank or video_b != blank -%}
          <div
            class="pli-block pli-block--video-grid pli-animate"
            style="padding-top:{{ vg_pad_top }}px;padding-bottom:{{ vg_pad_bot }}px;background-color:{{ grid_bg }};"
            {{ block.shopify_attributes }}
          >
            {%- if video_a != blank -%}
              <div class="pli-video-item">
                <video autoplay muted loop playsinline preload="metadata">
                  <source src="{{ video_a }}" type="video/mp4">
                </video>
              </div>
            {%- endif -%}
            {%- if video_b != blank -%}
              <div class="pli-video-item">
                <video autoplay muted loop playsinline preload="metadata">
                  <source src="{{ video_b }}" type="video/mp4">
                </video>
              </div>
            {%- endif -%}
          </div>
        {%- else -%}
          {%- comment -%} Placeholder visible solo en el editor {%- endcomment -%}
          <div
            class="pli-block pli-block--video-grid pli-video-placeholder"
            style="padding-top:{{ vg_pad_top }}px;padding-bottom:{{ vg_pad_bot }}px;"
            {{ block.shopify_attributes }}
          >
            <div class="pli-placeholder-inner">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="60" height="60" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><polygon points="10,8 16,12 10,16"/></svg>
              <p>Agrega las URLs de los videos en el editor</p>
            </div>
          </div>
        {%- endif -%}

      {%- endif -%}
    {%- endfor -%}

  </div>

  {%- comment -%} ── CSS integrado ────────────────────────────────── {%- endcomment -%}
  <style>
    /* ── Wrapper principal ─────────────────────────────────────── */
    #product-landing-images-{{ section.id }} {
      width: 100%;
      margin: 0;
      padding: 0;
      overflow: hidden;
      background: transparent;
    }

    /* ── Ocultar en desktop si la opción está activa ───────────── */
    @media (min-width: 750px) {
      #product-landing-images-{{ section.id }}.pli-hide-desktop {
        display: none !important;
      }
    }

    /* ── Bloque base ───────────────────────────────────────────── */
    .pli-block {
      width: 100%;
      display: block;
      margin: 0;
      box-sizing: border-box;
    }

    /* ══ IMAGEN ════════════════════════════════════════════════ */
    .pli-image {
      display: block;
      width: 100%;
      height: auto;
      max-width: 100%;
      object-fit: contain;
      margin: 0;
      padding: 0;
      border: none;
    }

    /* ══ BOTÓN RELEASIT ═══════════════════════════════════════ */
    /*
      Replica exactamente el .product-form__buttons del tema:
      contenedor blanco, padding generoso, botón ancho 100%.
    */
    .pli-block--cta {
      display: block;
      width: 100%;
    }
    .pli-rsi-btn {
      display: block;
      width: 100%;
      padding: 18px 24px;
      border: none;
      cursor: pointer;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 1.2;
      text-align: center;
      -webkit-tap-highlight-color: transparent;
      transition: filter 0.2s ease, transform 0.15s ease;
      /* Tipografía idéntica a Dawn */
      font-family: inherit;
    }
    .pli-rsi-btn:hover {
      filter: brightness(1.07);
    }
    .pli-rsi-btn:active {
      transform: scale(0.98);
    }
    .pli-rsi-btn:focus-visible {
      outline: 3px solid #005fcc;
      outline-offset: 2px;
    }

    /* ══ GRID DE VIDEOS ═══════════════════════════════════════ */
    /*
      Idéntico al .video-container-grid de base.css +
      las sobreescrituras del cojin product handle.
    */
    .pli-block--video-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      padding-left: 10px;
      padding-right: 10px;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }
    .pli-video-item {
      overflow: hidden;
      border-radius: 8px;
    }
    .pli-video-item video {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 8px;
    }
    @media screen and (max-width: 749px) {
      .pli-block--video-grid {
        gap: 8px;
        padding-left: 8px;
        padding-right: 8px;
      }
    }

    /* ── Placeholder editor ────────────────────────────────────── */
    .pli-placeholder-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 24px;
      gap: 12px;
      background: #f4f4f4;
      color: #888;
      font-size: 13px;
      text-align: center;
    }
    .pli-video-placeholder .pli-placeholder-inner {
      background: #1a1a1a;
      color: #666;
    }
    .pli-placeholder-svg,
    .pli-placeholder-inner svg {
      width: 60px;
      height: 60px;
      fill: #ccc;
      stroke: #ccc;
    }

    /* ── Animaciones IntersectionObserver ──────────────────────── */
    .pli-animate:not(.pli-visible) {
      opacity: 0;
      transform: translateY(30px);
    }
    .pli-animate.pli-visible {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
  </style>

  {%- comment -%} ── JavaScript ───────────────────────────────────── {%- endcomment -%}
  <script>
    (function () {
      'use strict';

      var SECTION_ID    = 'product-landing-images-{{ section.id }}';
      var RSI_SELECTOR  = '#_rsi-buy-now-button';
      var ANIMATE_CLASS = 'pli-animate';
      var VISIBLE_CLASS = 'pli-visible';
      var CLONE_ATTR    = 'data-pli-rsi-clone-target';

      /* ── Inyectar clon del botón Releasit real en cada wrapper ── */
      function injectClones(section) {
        var wrappers = section.querySelectorAll('[' + CLONE_ATTR + ']');
        if (!wrappers.length) return true; /* no hay bloques CTA, OK */

        var original = document.querySelector(RSI_SELECTOR);
        if (!original) return false; /* Releasit aún no ha pintado el botón */

        wrappers.forEach(function (wrapper) {
          if (wrapper.dataset.rsiInjected === 'true') return;

          var clone = original.cloneNode(true);
          clone.removeAttribute('id');
          clone.setAttribute('data-pli-clone', 'true');

          /* Al hacer clic en el clon → disparar el original */
          clone.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            original.click();
          });

          wrapper.appendChild(clone);
          wrapper.dataset.rsiInjected = 'true';
        });

        return true;
      }

      /* Reintentar hasta que Releasit pinte su botón */
      function tryInject(section, attemptsLeft) {
        if (attemptsLeft <= 0) return;
        if (injectClones(section)) return;
        window.setTimeout(function () { tryInject(section, attemptsLeft - 1); }, 300);
      }

      /* ── IntersectionObserver: anima al entrar, resetea al salir */
      function initObserver(section) {
        var targets = section.querySelectorAll('.' + ANIMATE_CLASS);
        if (!targets.length) return;

        if (!('IntersectionObserver' in window)) {
          targets.forEach(function (el) { el.classList.add(VISIBLE_CLASS); });
          return;
        }

        var inObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add(VISIBLE_CLASS);
              inObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.05, rootMargin: '0px 0px -30px 0px' });

        var outObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) {
              entry.target.classList.remove(VISIBLE_CLASS);
              inObs.observe(entry.target);
            }
          });
        }, { threshold: 0 });

        targets.forEach(function (el) {
          inObs.observe(el);
          outObs.observe(el);
        });
      }

      /* ── Click en imágenes con acción open_releasit ─────────── */
      function bindImageActions(section) {
        section.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-pli-img-action="open_releasit"]');
          if (!btn) return;
          e.preventDefault();
          var original = document.querySelector(RSI_SELECTOR);
          if (original) original.click();
        });
      }

      /* ── Init ─────────────────────────────────────────────────── */
      function init() {
        var section = document.getElementById(SECTION_ID);
        if (!section) return;

        bindImageActions(section);

        /* Observar el DOM por si Releasit llega después */
        if (!injectClones(section)) {
          var mo = new MutationObserver(function () {
            if (document.querySelector(RSI_SELECTOR)) {
              mo.disconnect();
              tryInject(section, 10);
            }
          });
          mo.observe(document.body, { childList: true, subtree: true });
        }

        initObserver(section);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Landing de imágenes",
  "tag": "div",
  "class": "section-product-landing-images",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Visibilidad"
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Ocultar en escritorio",
      "info": "Solo visible en móvil (< 750px). Ideal para landings de Facebook Ads.",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "🖼 Imagen",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Texto alternativo (SEO)",
          "info": "Describe la imagen para accesibilidad y buscadores."
        },
        {
          "type": "header",
          "content": "Acción al hacer clic"
        },
        {
          "type": "select",
          "id": "click_action",
          "label": "Acción al hacer clic",
          "options": [
            { "value": "none",           "label": "Ninguna" },
            { "value": "open_releasit",  "label": "Abrir formulario Releasit (COD)" }
          ],
          "default": "none"
        },
        {
          "type": "header",
          "content": "Espaciado"
        },
        {
          "type": "range",
          "id": "padding_top",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Espaciado superior",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Espaciado inferior",
          "default": 0
        }
      ]
    },
    {
      "type": "cta_releasit",
      "name": "🛒 Botón Releasit",
      "settings": [
        {
          "type": "paragraph",
          "content": "Muestra el mismo botón que configuraste en la app Releasit. El diseño y texto provienen directamente de Releasit."
        },
        {
          "type": "header",
          "content": "Espaciado"
        },
        {
          "type": "range",
          "id": "padding_top",
          "min": 0,
          "max": 80,
          "step": 4,
          "unit": "px",
          "label": "Espaciado superior",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "min": 0,
          "max": 80,
          "step": 4,
          "unit": "px",
          "label": "Espaciado inferior",
          "default": 0
        }
      ]
    },
    {
      "type": "video_grid",
      "name": "🎥 Grid de videos",
      "settings": [
        {
          "type": "text",
          "id": "video_url_a",
          "label": "URL video izquierda",
          "info": "Pega la URL directa del archivo .mp4 (Shopify Files o CDN externo)"
        },
        {
          "type": "text",
          "id": "video_url_b",
          "label": "URL video derecha",
          "info": "Pega la URL directa del archivo .mp4 (Shopify Files o CDN externo)"
        },
        {
          "type": "header",
          "content": "Estilo"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Color de fondo del grid",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "Espaciado"
        },
        {
          "type": "range",
          "id": "padding_top",
          "min": 0,
          "max": 80,
          "step": 4,
          "unit": "px",
          "label": "Espaciado superior",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "min": 0,
          "max": 80,
          "step": 4,
          "unit": "px",
          "label": "Espaciado inferior",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing de imágenes",
      "blocks": [
        { "type": "image" },
        { "type": "cta_releasit" },
        { "type": "image" },
        { "type": "video_grid" },
        { "type": "cta_releasit" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
