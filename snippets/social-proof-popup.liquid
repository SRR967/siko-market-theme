{%- comment -%}
  Snippet: social-proof-popup.liquid
  Muestra un popup rotativo de prueba social simulando compras recientes.
  Usa los datos de las variantes para actualizar la imagen si el usuario cambia opciones.
{%- endcomment -%}

{%- assign popup_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}
{%- capture variant_image_map -%}
  {
    {%- for variant in product.variants -%}
      {%- assign media = variant.featured_media | default: product.featured_media -%}
      "{{ variant.id }}":"{% if media %}{{ media.preview_image | image_url: width: 200 }}{% endif %}"{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  }
{%- endcapture -%}

<div
  class="social-proof-popup"
  data-social-proof-popup
  data-product-title="{{ product.title | escape }}"
  data-product-image="{% if popup_media %}{{ popup_media.preview_image | image_url: width: 200 }}{% endif %}"
  data-variant-images='{{ variant_image_map | strip_newlines | escape }}'
  aria-live="polite"
  aria-atomic="true"
>
  <div class="social-proof-popup__image-wrap">
    <img
      class="social-proof-popup__image"
      data-social-proof-image
      src="{% if popup_media %}{{ popup_media.preview_image | image_url: width: 200 }}{% endif %}"
      alt="{{ product.title | escape }}"
      loading="lazy"
      width="88"
      height="88"
    >
  </div>
  <div class="social-proof-popup__content">
    <p class="social-proof-popup__customer" data-social-proof-customer>Eduardo...</p>
    <p class="social-proof-popup__purchase">
      Compró <span class="social-proof-popup__product" data-social-proof-product>{{ product.title | escape }}</span>
    </p>
    <p class="social-proof-popup__location">
      <span aria-hidden="true">📍</span>
      <span data-social-proof-location>Desde Cartagena, ahora mismo</span>
    </p>
  </div>
</div>

<script src="{{ 'social-proof-popup.js' | asset_url }}" defer="defer"></script>
